#!/usr/bin/env bash

set -euo pipefail

ZERO_OID="0000000000000000000000000000000000000000"
MAX_COMMITS="${COMMIT_LOG_MAX_COMMITS:-25}"

REMOTE_NAME="${1:-unknown-remote}"
REMOTE_URL="${2:-unknown-url}"

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
log_file="${COMMIT_LOG_FILE:-$repo_root/logging/commit_log.md}"
timestamp="$(date -u +"%Y-%m-%d %H:%M:%SZ")"

mkdir -p "$(dirname "$log_file")"
touch "$log_file"

append_line() {
  printf "%s\n" "$1" >> "$log_file"
}

first_nonempty_line() {
  sed -n '/[^[:space:]]/ { s/^[[:space:]]*//; p; q; }'
}

build_purpose_line() {
  local sha="$1"
  local files="$2"
  local msg_body purpose_line scope_list
  local adds mods dels

  msg_body="$(git show -s --format='%B' "$sha" | tail -n +2 | first_nonempty_line || true)"
  if [[ -n "${msg_body:-}" ]]; then
    if [[ ${#msg_body} -gt 180 ]]; then
      msg_body="${msg_body:0:177}..."
    fi
    echo "$msg_body"
    return
  fi

  adds="$(printf "%s\n" "$files" | awk -F'\t' '$1 ~ /^A/ {c++} END {print c+0}')"
  mods="$(printf "%s\n" "$files" | awk -F'\t' '$1 ~ /^M/ {c++} END {print c+0}')"
  dels="$(printf "%s\n" "$files" | awk -F'\t' '$1 ~ /^D/ {c++} END {print c+0}')"

  scope_list="$(
    printf "%s\n" "$files" \
      | awk -F'\t' 'NF >= 2 {print $2}' \
      | awk -F'/' '{print $1}' \
      | sed '/^$/d' \
      | sort -u \
      | awk 'BEGIN {first=1} {if (!first) printf ", "; printf "%s", $0; first=0} END {printf "\n"}'
  )"

  purpose_line=""
  if [[ "$adds" -gt 0 ]]; then
    purpose_line="adds $adds"
  fi
  if [[ "$mods" -gt 0 ]]; then
    if [[ -n "$purpose_line" ]]; then
      purpose_line="$purpose_line, modifies $mods"
    else
      purpose_line="modifies $mods"
    fi
  fi
  if [[ "$dels" -gt 0 ]]; then
    if [[ -n "$purpose_line" ]]; then
      purpose_line="$purpose_line, deletes $dels"
    else
      purpose_line="deletes $dels"
    fi
  fi

  if [[ -z "$purpose_line" ]]; then
    purpose_line="updates files"
  fi

  if [[ -n "${scope_list:-}" ]]; then
    echo "This commit $purpose_line across $scope_list."
  else
    echo "This commit $purpose_line."
  fi
}

ensure_log_header() {
  if ! grep -q "^# Remote Commit Log" "$log_file"; then
    append_line "# Remote Commit Log"
    append_line ""
    append_line "Append-only history generated by .githooks/pre-push."
    append_line "Entries are grouped by branch and extend commit messages with file-level change detail."
  fi
}

ensure_log_header

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref:-}" ]] && continue

  if [[ "$local_ref" == "(delete)" || "$local_sha" == "$ZERO_OID" ]]; then
    continue
  fi

  if [[ "$remote_ref" == refs/heads/* ]]; then
    branch="${remote_ref#refs/heads/}"
  elif [[ "$local_ref" == refs/heads/* ]]; then
    branch="${local_ref#refs/heads/}"
  else
    continue
  fi

  section_header="## Branch: $branch"
  if ! grep -qF "$section_header" "$log_file"; then
    append_line ""
    append_line "$section_header"
  fi

  append_line ""
  append_line "### $timestamp - Push to $REMOTE_NAME"
  append_line "- Remote URL: $REMOTE_URL"
  append_line "- Remote ref: $remote_ref"

  if [[ "$remote_sha" == "$ZERO_OID" ]]; then
    append_line "- Range: new branch up to $local_sha"
    commit_list="$(git rev-list --reverse --max-count "$MAX_COMMITS" "$local_sha")"
  else
    append_line "- Range: $remote_sha..$local_sha"
    if git cat-file -e "${remote_sha}^{commit}" 2>/dev/null; then
      commit_list="$(git rev-list --reverse --max-count "$MAX_COMMITS" "$remote_sha..$local_sha")"
    else
      append_line "- Range note: remote tip $remote_sha not found locally; using local history up to $local_sha"
      commit_list="$(git rev-list --reverse --max-count "$MAX_COMMITS" "$local_sha")"
    fi
  fi

  append_line "- Commits:"

  if [[ -z "$commit_list" ]]; then
    append_line "  - none (possibly already synchronized)"
    continue
  fi

  while IFS= read -r sha; do
    [[ -z "$sha" ]] && continue

    short_sha="$(git rev-parse --short "$sha")"
    subject="$(git show -s --format='%s' "$sha")"
    author="$(git show -s --format='%an <%ae>' "$sha")"
    commit_date="$(git show -s --format='%cI' "$sha")"

    append_line "  - $short_sha $subject"
    append_line "    - Author: $author"
    append_line "    - Commit date: $commit_date"
    files="$(git show --pretty='' --name-status --no-renames "$sha")"
    purpose_line="$(build_purpose_line "$sha" "$files")"
    append_line "    - Purpose: $purpose_line"
    append_line "    - Files:"

    if [[ -z "$files" ]]; then
      append_line "      - none"
    else
      while IFS=$'\t' read -r status path rest; do
        [[ -z "${status:-}" ]] && continue
        append_line "      - $status $path"
      done <<< "$files"
    fi
  done <<< "$commit_list"
done

exit 0
