# Claude Code self-improvement configuration
# Edit these thresholds based on observed signal quality after real sessions.
# All scripts source this file before running.

# ── Verification checks (language-agnostic) ────────────────────────────────────
# Each entry: name|file_regex|root_marker|command|error_code_regex
# - file_regex: bash regex matched against the edited/modified file path
# - root_marker: search upward for this file; use "project" to force repo root
# - error_code_regex: optional; pattern used to extract error codes for trends
CHECK_DEFINITIONS=(
  "typescript|\\.tsx?$|tsconfig.json|npx tsc --noEmit --skipLibCheck|TS[0-9]{4}"
)

# Command execution defaults
CHECK_TIMEOUT_SECS=45
CHECK_OUTPUT_LINES=40

# ── Error detection ────────────────────────────────────────────────────────────
# session-end.sh: total verification errors per session that trigger the
# skill-improvement-loop flag
ERROR_THRESHOLD=2
# Deprecated: TS_ERROR_THRESHOLD is still read for backward compatibility.

# post-edit-check.sh: minimum seconds between checks for the same root+check
# Lower = faster feedback, higher CPU cost. Raise to 60+ for slow machines.
POST_EDIT_RATE_LIMIT_SECS=30

# ── Pattern detection ──────────────────────────────────────────────────────────
# analyze-patterns.sh: same error code seen N+ times across the log → flagged
PATTERN_ERROR_CODE_MIN=2

# analyze-patterns.sh: same file appears in errors N+ times → flagged as "hot file"
PATTERN_FILE_ERROR_MIN=3

# analyze-patterns.sh / update-skill-memory.sh:
# same skill named in "Skill gap:" entries N+ times → escalated priority improvement
SKILL_GAP_ESCALATE_MIN=2

# ── Notification priorities ────────────────────────────────────────────────────
# ntfy.sh priority for smoke test failures: min | low | default | high | urgent
SMOKE_FAIL_NOTIFY_PRIORITY=high

# ntfy.sh priority for skill gap escalation
SKILL_GAP_NOTIFY_PRIORITY=urgent
